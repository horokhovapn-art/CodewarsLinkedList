class Node(object):
    def __init__(self, data=None):
        self.data = data
        self.next = None
    
class Context(object):
    def __init__(self, first, second):
        self.first = first
        self.second = second
    
def alternating_split(head):
    if not head or not head.next:
        raise ValueError
    first_head = head
    second_head = head.next
    head = head.next.next
    first = first_head
    second = second_head
    while head:
        first.next = head
        first = first.next
        if head.next:
            second.next = head.next
            second = second.next
            head = head.next.next
        else:
            head = None
        
    first.next = None
    second.next = None
    return Context(first_head,second_head)
