""" For your information:
class Node(object):
    def __init__(self, data):
        self.data = data
        self.next = None
"""

def sorted_insert(head, data):
    if not head:
        new_node = Node(data)
        new_node.next = head
        return new_node
    node = head
    new_node = Node(data)
    if node.data > new_node.data:
        new_node.next = node
        return new_node
    while new_node.data > node.data and node.next:
        prev_node = node
        node = node.next
    if new_node.data > node.data:
        node.next = new_node
        return head
    prev_node.next = new_node
    new_node.next = node
    return head
